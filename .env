# Environnement
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# Database
DATABASE_URL=sqlite:///./data/orl.db

# Nginx
NGINX_WORKER_PROCESSES=auto

# Python
PYTHONUNBUFFERED=1

# Resource Limits (dev)
API_MEMORY_LIMIT=4G
API_MEMORY_RESERVATION=2G
API_CPU_LIMIT=2
API_CPU_RESERVATION=1

DASHBOARD_MEMORY_LIMIT=2G
DASHBOARD_MEMORY_RESERVATION=1G
DASHBOARD_CPU_LIMIT=1
DASHBOARD_CPU_RESERVATION=0.5

NGINX_MEMORY_LIMIT=512M
NGINX_MEMORY_RESERVATION=256M
NGINX_CPU_LIMIT=0.5
NGINX_CPU_RESERVATION=0.25
